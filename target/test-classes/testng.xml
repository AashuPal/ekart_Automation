<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="eKart Automation Suite" verbose="1" parallel="false">

    <test name="Navigation Tests">
        <classes>
            <class name="com.ekart.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Registration Tests">
        <classes>
            <class name="com.ekart.tests.RegistrationTest"/>
        </classes>
    </test>

    <test name="Login Tests">
        <classes>
            <class name="com.ekart.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Alert Tests">
        <classes>
            <class name="com.ekart.tests.AlertTest"/>
        </classes>
    </test>

    <test name="Logout and Session Handling Tests">
        <classes>
            <class name="com.ekart.tests.LogoutTest"/>
        </classes>
    </test>

</suite>